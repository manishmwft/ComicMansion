<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <div class="text-secondary small">Content Management</div>
  </div>

  <a href="/admin/comics" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>
    Back
  </a>
</div>

<form method="POST" enctype="multipart/form-data">
  <div class="row g-4">

    <!-- LEFT COLUMN -->
    <div class="col-lg-8">

      <!-- BASIC INFO -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title mb-0">Basic Info</h3>
        </div>

        <div class="card-body">
          <div class="mb-3">
            <label class="form-label">Title</label>
            <input
              type="text"
              name="title"
              class="form-control"
              placeholder="Enter comic title"
              value="<%= comic?.title || '' %>"
              required
            />
          </div>

          <div class="mb-3">
            <label class="form-label">Description</label>
            <textarea
              name="description"
              class="form-control"
              rows="6"
              placeholder="Write comic description..."
            ><%= comic?.description || '' %></textarea>
          </div>

          <div class="row g-3">
            <div class="col-md-6">
              <label class="form-label">Genre</label>
              <select name="genre" class="form-select">
                <% const genres = ["General", "Action", "Adventure", "Horror", "Thriller", "Sci-Fi", "Mythology", "Fantasy", "Romance", "Comedy", "Crime", "Drama"]; %>
                <% genres.forEach((genre) => { %>
                  <option
                    value="<%= genre %>"
                    <%= (comic?.genre || "General") === genre ? "selected" : "" %>
                  >
                    <%= genre %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Language</label>
              <select name="language" class="form-select">
                <% const languages = ["English", "Hindi", "Kannada", "Tamil", "Telugu", "Malayalam", "Marathi", "Bengali"]; %>
                <% languages.forEach((language) => { %>
                  <option
                    value="<%= language %>"
                    <%= (comic?.language || "English") === language ? "selected" : "" %>
                  >
                    <%= language %>
                  </option>
                <% }) %>
              </select>
            </div>
          </div>

          <div class="row g-3 mt-1">
            <div class="col-md-6">
              <label class="form-label">Age Rating</label>
              <select name="age_rating" class="form-select">
                <% const ratings = ["All", "7+", "13+", "16+", "18+"]; %>
                <% ratings.forEach((rating) => { %>
                  <option
                    value="<%= rating %>"
                    <%= (comic?.age_rating || "13+") === rating ? "selected" : "" %>
                  >
                    <%= rating %>
                  </option>
                <% }) %>
              </select>
            </div>

            <div class="col-md-6">
              <label class="form-label">Tags</label>
              <input
                type="text"
                name="tags"
                class="form-control"
                placeholder="mystery, indian, action"
                value="<%= Array.isArray(comic?.tags) ? comic.tags.join(', ') : '' %>"
              />
              <div class="form-hint mt-1">
                Separate tags with commas.
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- READING MODE -->
      <div class="card">
        <div class="card-header">
          <h3 class="card-title mb-0">Reading Mode</h3>
        </div>

        <div class="card-body">
          <div class="row g-3">

            <div class="col-md-6">
              <label class="form-selectgroup-item w-100">
                <input
                  type="radio"
                  name="view_mode"
                  value="vertical"
                  class="form-selectgroup-input"
                  <%= !comic?.view_mode || comic?.view_mode === 'vertical' ? 'checked' : '' %>
                >

                <span class="form-selectgroup-label d-flex align-items-center justify-content-center py-3">
                  <i class="bi bi-phone me-2"></i>
                  Vertical Reading
                </span>
              </label>
            </div>

            <div class="col-md-6">
              <label class="form-selectgroup-item w-100">
                <input
                  type="radio"
                  name="view_mode"
                  value="horizontal"
                  class="form-selectgroup-input"
                  <%= comic?.view_mode === 'horizontal' ? 'checked' : '' %>
                >

                <span class="form-selectgroup-label d-flex align-items-center justify-content-center py-3">
                  <i class="bi bi-tablet-landscape me-2"></i>
                  Horizontal Reading
                </span>
              </label>
            </div>

          </div>

          <div class="form-hint mt-3">
            Choose how users will read this comic in the mobile app.
          </div>
        </div>
      </div>

    </div>

    <!-- RIGHT COLUMN -->
    <div class="col-lg-4">
<!-- FEATURED SETTINGS -->
<div class="card mb-4">
  <div class="card-header">
    <h3 class="card-title mb-0">Home Visibility</h3>
  </div>

  <div class="card-body">
    <label class="form-check form-switch">
      <input
        class="form-check-input"
        type="checkbox"
        name="is_featured"
        value="true"
        <%= comic?.is_featured ? "checked" : "" %>
      >
      <span class="form-check-label">
        Show in Hero Banner
      </span>
    </label>

    <div class="form-hint mt-2">
      Featured comics appear in the top home carousel.
    </div>
  </div>
</div>
      <!-- THUMBNAIL -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title mb-0">Thumbnail</h3>
        </div>

        <div class="card-body text-center">
          <div class="mb-3 d-flex justify-content-center">
            <% if (comic?.thumbnail_url) { %>
              <img src="<%= comic.thumbnail_url %>" id="thumbnailPreview" class="thumb-preview mb-2">
            <% } else { %>
              <div id="thumbnailPreview" class="thumb-preview d-flex align-items-center justify-content-center mb-2">
                <i class="bi bi-image"></i>
              </div>
            <% } %>
          </div>

          <input
            type="file"
            name="thumbnail"
            class="form-control"
            accept="image/png,image/jpeg,image/webp"
            onchange="previewThumbnail(event)"
          />

          <div class="form-hint mt-2">
            Upload JPG, PNG, or WEBP thumbnail.
          </div>
        </div>
      </div>

      <!-- ACTION -->
      <div class="card">
        <div class="card-body d-grid gap-2">
          <button class="btn btn-primary">
            <i class="bi bi-check-circle me-1"></i>
            <%= comic?.id ? 'Update Comic' : 'Create Comic' %>
          </button>

          <a href="/admin/comics" class="btn btn-outline-secondary">
            Cancel
          </a>
        </div>
      </div>

    </div>

  </div>
</form>

<script>
function previewThumbnail(event) {
  const file = event.target.files[0];
  if (!file) return;

  const preview = document.getElementById("thumbnailPreview");
  preview.outerHTML = `
    <img 
      src="${URL.createObjectURL(file)}" 
      id="thumbnailPreview" 
      class="thumb-preview mb-2"
    >
  `;
}
</script>