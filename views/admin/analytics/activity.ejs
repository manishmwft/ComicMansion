<div class="card">

  <div class="card-header d-flex justify-content-between align-items-center">

    <div>
      <h2 class="mb-1">
        Activity Logs
      </h2>

      <div class="text-secondary">
        Reader activity across platform
      </div>
    </div>

    <span class="badge bg-blue-lt text-blue">

      <%= activityLogs.length %> Logs
    </span>

  </div>

  <% if (
      !activityLogs ||
      activityLogs.length === 0
     ) { %>

    <div class="empty-state">

      <div class="mb-3">
        <i
          class="bi bi-activity"
          style="font-size:40px;"
        ></i>
      </div>

      <h3>No activity yet</h3>

    </div>

  <% } else { %>

    <div class="table-responsive">

      <table class="table table-vcenter card-table">

        <thead>
          <tr>
            <th>User</th>
            <th>Type</th>
            <th>Comic</th>
            <th>Episode</th>
            <th>Source</th>
            <th>Platform</th>
            <th>Time</th>
          </tr>
        </thead>

        <tbody>

        <% activityLogs.forEach(log => { %>

          <tr>

            <td>
              <%= log.user_id || '-' %>
            </td>

        <td>

  <% if (log.activity_type === 'read') { %>

    <span class="badge bg-green-lt text-green">
      Read
    </span>

  <% } else { %>

    <span class="badge bg-cyan-lt text-cyan">
      View
    </span>

  <% } %>

</td>

            <td>
              <%= log.comic?.title || '-' %>
            </td>

            <td>
              <%= log.episode?.title || '-' %>
            </td>

            <td>
              <%= log.source || '-' %>
            </td>

            <td>
              <%= log.platform || '-' %>
            </td>

            <td>
              <%= new Date(
                    log.createdAt
                  ).toLocaleString()
              %>
            </td>

          </tr>

        <% }) %>

        </tbody>

      </table>

    </div>

  <% } %>

</div>  