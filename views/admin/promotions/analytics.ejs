<div class="d-flex justify-content-between align-items-center mb-4"><div><h2 class="mb-1"><%= promotion.title %></h2><div class="text-muted">Promotion analytics</div></div><a href="/admin/promotions" class="btn btn-outline-secondary">Back</a></div>
<div class="row mb-4"><div class="col-md-4"><div class="card card-body"><div class="text-muted">Impressions</div><div class="h1"><%= promotion.total_impressions %></div></div></div><div class="col-md-4"><div class="card card-body"><div class="text-muted">Clicks</div><div class="h1"><%= promotion.total_clicks %></div></div></div><div class="col-md-4"><div class="card card-body"><div class="text-muted">CTR</div><div class="h1"><%= promotion.total_impressions ? ((promotion.total_clicks / promotion.total_impressions) * 100).toFixed(2) : '0.00' %>%</div></div></div></div>
<div class="card"><div class="card-header"><h3 class="card-title">Recent Events</h3></div><div class="table-responsive"><table class="table card-table"><thead><tr><th>Event</th><th>User</th><th>Device</th><th>Platform</th><th>Time</th></tr></thead><tbody><% events.forEach(event => { %><tr><td><span class="badge <%= event.event_type === 'click' ? 'bg-green-lt' : 'bg-blue-lt' %>"><%= event.event_type %></span></td><td><%= event.user_id || 'Guest' %></td><td class="small"><%= event.device_id %></td><td><%= event.platform %></td><td><%= new Date(event.occurred_at).toLocaleString() %></td></tr><% }) %></tbody></table></div></div>
