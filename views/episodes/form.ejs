<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <div class="text-secondary small">
      <a href="/admin/comics" class="text-decoration-none">Comics</a>
      <span class="mx-1">/</span>
      <a href="/admin/episodes/<%= comic_id %>" class="text-decoration-none">Episodes</a>
      <span class="mx-1">/</span>
      <%= episode && episode.id ? 'Edit' : 'Create' %>
    </div>
    <br>
    <h2 class="page-title m-0">
      <%= episode && episode.id ? 'Edit Episode' : 'Create Episode' %>
    </h2>
  </div>

  <a href="/admin/episodes/<%= comic_id %>" class="btn btn-outline-secondary">
    <i class="bi bi-arrow-left me-1"></i>
    Back
  </a>
</div>

<form method="POST" enctype="multipart/form-data">
  <div class="row">

    <!-- LEFT -->
    <div class="col-lg-8">
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title mb-0">Episode Details</h3>
        </div>

        <div class="card-body">

          <!-- TITLE -->
          <div class="mb-3">
            <label class="form-label">Episode Title</label>
            <input
              type="text"
              name="title"
              class="form-control"
              placeholder="Enter episode title"
              value="<%= episode?.title || '' %>"
              required
            />
          </div>

          <!-- INFO -->
          <div class="alert alert-blue-lt">
            Episode number is automatically assigned based on order.
          </div>

        </div>
      </div>
    </div>

    <!-- RIGHT -->
    <div class="col-lg-4">

      <!-- COVER -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title mb-0">Episode Cover</h3>
        </div>

        <div class="card-body text-center">

          <div class="mb-3">
            <% if (episode?.cover_url) { %>
              <img src="<%= episode.cover_url %>" id="episodePreview" class="thumb-preview mb-2">
            <% } else { %>
              <div id="episodePreview" class="thumb-preview d-flex align-items-center justify-content-center mb-2">
                <i class="bi bi-image"></i>
              </div>
            <% } %>
          </div>

          <input
            type="file"
            name="episode_cover"
            class="form-control"
            accept="image/png,image/jpeg,image/webp"
            onchange="previewEpisodeCover(event)"
          />

          <div class="form-hint mt-2">
            Upload JPG / PNG / WEBP
          </div>
        </div>
      </div>

      <!-- ACCESS -->
      <div class="card mb-4">
        <div class="card-header">
          <h3 class="card-title mb-0">Access Settings</h3>
        </div>

        <div class="card-body">
          <label class="form-check form-switch">
            <input
              class="form-check-input"
              type="checkbox"
              name="is_paid"
              value="true"
              <%= episode?.is_paid ? 'checked' : '' %>
            >
            <span class="form-check-label">Paid Episode</span>
          </label>

          <div class="form-hint mt-2">
            Enable if users must purchase this episode
          </div>
        </div>
      </div>

      <!-- ACTION -->
      <div class="card">
        <div class="card-body d-grid gap-2">

          <button class="btn btn-primary">
            <i class="bi bi-check-circle me-1"></i>
            <%= episode?.id ? 'Update Episode' : 'Create Episode' %>
          </button>

          <a href="/admin/episodes/<%= comic_id %>" class="btn btn-outline-secondary">
            Cancel
          </a>

        </div>
      </div>

    </div>
  </div>
</form>

<script>
function previewEpisodeCover(event) {
  const file = event.target.files[0];
  if (!file) return;

  const preview = document.getElementById("episodePreview");

  preview.outerHTML = `
    <img src="${URL.createObjectURL(file)}"
         id="episodePreview"
         class="thumb-preview mb-2">
  `;
}
</script>