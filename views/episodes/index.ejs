<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <div class="text-secondary small">
      <a href="/admin/comics" class="text-decoration-none">Comics</a>
      <span class="mx-1">/</span>
      Episodes
    </div>
<br>
    <h2 class="page-title m-0">
      <!-- <span class="text-secondary">Comic :</span>
      <%= comic?.title || '-' %> -->
    </h2>
  </div>

  <div class="d-flex gap-2">
    <a href="/admin/comics" class="btn btn-outline-secondary">
      <i class="bi bi-arrow-left me-1"></i>
      Back to Comics
    </a>

    <a href="/admin/episodes/add/<%= comic_id %>" class="btn btn-primary">
      <i class="bi bi-plus-circle me-1"></i>
      Add Episode
    </a>
  </div>
</div>

<div class="card">
  <div class="card-header">
    <div class="w-100 d-flex justify-content-between align-items-center">
      <h3 class="card-title mb-0">All Episodes</h3>
      <span class="badge bg-blue-lt"><%= episodes.length %> total</span>
    </div>
  </div>

  <% if (!episodes || episodes.length === 0) { %>
    <div class="empty-state">
      <div class="mb-3">
        <i class="bi bi-collection-play" style="font-size: 44px;"></i>
      </div>

      <h3 class="mb-2">No episodes found</h3>
      <p class="mb-3">Create the first episode for this comic.</p>

      <a href="/admin/episodes/add/<%= comic_id %>" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i>
        Add Episode
      </a>
    </div>
  <% } else { %>
    <div class="table-responsive">
      <table class="table table-vcenter card-table">
        <thead>
          <tr>
            <th style="width: 120px;">Episode No.</th>
            <th style="width: 90px;">Cover</th>
            <th>Title</th>
            <th style="width: 130px;">Access</th>
            <th style="width: 180px;">Pages</th>
            <th class="text-end" style="width: 220px;">Actions</th>
          </tr>
        </thead>

        <tbody>
          <% episodes.forEach(episode => { %>
            <tr>
              <td>
                <span class="badge bg-azure-lt">
                  #<%= episode.episode_number ?? 0 %>
                </span>
              </td>

              <td>
                <% if (episode.cover_url) { %>
                  <img src="<%= episode.cover_url %>" class="thumb-preview" alt="Episode cover">
                <% } else { %>
                  <div class="thumb-preview d-flex align-items-center justify-content-center text-secondary">
                    <i class="bi bi-image"></i>
                  </div>
                <% } %>
              </td>

              <td>
                <div class="fw-semibold"><%= episode.title || 'Untitled Episode' %></div>
                <div class="text-secondary small"><%= episode.id %></div>
              </td>

              <td>
                <% if (episode.is_paid) { %>
                  <span class="badge bg-orange-lt">Paid</span>
                <% } else { %>
                  <span class="badge bg-green-lt">Free</span>
                <% } %>
              </td>

              <td>
                <a href="/admin/pages/<%= episode.id %>" class="btn btn-outline-primary btn-sm">
                  <i class="bi bi-images me-1"></i>
                  View Pages
                </a>
              </td>

              <td class="text-end">
                <div class="btn-list justify-content-end flex-nowrap">
                  <a href="/admin/episodes/edit/<%= episode.id %>" class="btn btn-outline-warning btn-sm">
                    <i class="bi bi-pencil-square me-1"></i>
                    Edit
                  </a>

                  <a href="javascript:void(0);"
                     class="btn btn-outline-danger btn-sm"
                     onclick="openDeleteModal('<%= episode.id %>', '/admin/episodes/delete/')">
                    <i class="bi bi-trash me-1"></i>
                    Delete
                  </a>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>