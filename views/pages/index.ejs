<style>
  .page-sort-card,
  .page-sort-row {
    cursor: grab;
  }

  .page-sort-card:active,
  .page-sort-row:active {
    cursor: grabbing;
  }

  .page-sort-card.dragging,
  .page-sort-row.dragging {
    opacity: 0.45;
    transform: scale(0.98);
  }

  .drag-handle {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: #667085;
    font-size: 13px;
    user-select: none;
  }

  .drag-handle i {
    font-size: 18px;
  }

  #orderStatus {
    min-height: 24px;
  }
</style>

<div
  id="pageReorderRoot"
  data-episode-id="<%= episode_id %>"
>
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <div class="page-pretitle">
        Comics / Pages
      </div>

      <br>

      <h2 class="page-title">
        <%= episode?.title || "Pages" %>
      </h2>
    </div>

    <div class="d-flex align-items-center gap-2">
      <div
        class="btn-group"
        role="group"
        aria-label="Page view mode"
      >
        <button
          type="button"
          id="gridViewButton"
          class="btn btn-outline-primary"
          title="Grid view"
        >
          <i class="bi bi-grid-3x3-gap"></i>
        </button>

        <button
          type="button"
          id="listViewButton"
          class="btn btn-outline-primary"
          title="List view"
        >
          <i class="bi bi-list-ul"></i>
        </button>
      </div>

      <a
        href="/admin/episodes/<%= comic?.id %>"
        class="btn btn-light"
      >
        <i class="bi bi-arrow-left"></i>
        Back
      </a>

      <a
        href="/admin/pages/add/<%= episode_id %>"
        class="btn btn-primary"
      >
        <i class="bi bi-plus-circle"></i>
        Add Page
      </a>
    </div>
  </div>

  <div
    id="orderStatus"
    class="mb-3"
  ></div>

  <div class="card">
    <div
      class="card-header d-flex justify-content-between align-items-center"
    >
      <div>
        <h3 class="card-title mb-1">
          All Pages
        </h3>

        <div class="text-muted small">
          Drag and drop a page to change its reading order.
          Changes save automatically.
        </div>
      </div>

      <span class="badge bg-primary-lt">
        <%= pages.length %> total
      </span>
    </div>

    <!-- GRID VIEW -->
    <div id="gridView">
      <div class="card-body">
        <% if (!pages || pages.length === 0) { %>
          <div class="text-center py-5">
            <i class="bi bi-images fs-1 text-muted"></i>

            <h3 class="mt-3">
              No pages uploaded
            </h3>

            <p class="text-muted">
              Upload the first page for this episode.
            </p>

            <a
              href="/admin/pages/add/<%= episode_id %>"
              class="btn btn-primary"
            >
              <i class="bi bi-plus-circle me-1"></i>
              Add Page
            </a>
          </div>
        <% } else { %>
          <div
            class="row"
            id="sortableGrid"
          >
            <% pages.forEach((page, index) => { %>
              <div
                class="col-xl-3 col-lg-4 col-md-6 mb-4 page-sort-card"
                draggable="true"
                data-page-id="<%= page.id %>"
              >
                <div class="card h-100 border-0 shadow-sm">
                  <div class="card-body">
                    <div
                      class="d-flex justify-content-between align-items-center mb-3"
                    >
                      <span
                        class="badge bg-primary-lt page-number-badge"
                      >
                        Page <%= page.page_number || index + 1 %>
                      </span>

                      <span
                        class="drag-handle"
                        title="Drag to reorder"
                      >
                        <i class="bi bi-grip-vertical"></i>
                        Drag
                      </span>
                    </div>

                    <div class="text-center mb-3">
                      <% if (page.image_url) { %>
                        <img
                          src="<%= page.image_url %>"
                          class="img-fluid rounded"
                          alt="Page <%= page.page_number || index + 1 %>"
                          loading="lazy"
                          style="
                            height: 180px;
                            width: auto;
                            object-fit: contain;
                          "
                        >
                      <% } else { %>
                        <div
                          class="border rounded d-flex align-items-center justify-content-center"
                          style="height: 180px;"
                        >
                          <i class="bi bi-image text-muted fs-1"></i>
                        </div>
                      <% } %>
                    </div>

                    <p class="small text-muted text-break mb-3">
                      <%= page.id %>
                    </p>

                    <div class="mb-3">
                      <span class="badge bg-azure-lt">
                        <%= comic?.view_mode || "vertical" %>
                      </span>
                    </div>

                    <div class="d-grid gap-2">
                      <a
                        href="/admin/pages/edit/<%= page.id %>"
                        class="btn btn-outline-warning"
                      >
                        <i class="bi bi-pencil-square me-1"></i>
                        Edit
                      </a>

                      <a
                        href="/admin/pages/delete/<%= page.id %>"
                        class="btn btn-outline-danger js-delete-page"
                      >
                        <i class="bi bi-trash me-1"></i>
                        Delete
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            <% }) %>
          </div>
        <% } %>
      </div>
    </div>

    <!-- LIST VIEW -->
    <div
      id="listView"
      style="display: none;"
    >
      <% if (!pages || pages.length === 0) { %>
        <div class="card-body text-center py-5">
          <i class="bi bi-images fs-1 text-muted"></i>

          <h3 class="mt-3">
            No pages uploaded
          </h3>

          <p class="text-muted">
            Upload the first page for this episode.
          </p>
        </div>
      <% } else { %>
        <div class="table-responsive">
          <table class="table table-hover table-vcenter card-table">
            <thead>
              <tr>
                <th>Move</th>
                <th>Page</th>
                <th>Preview</th>
                <th>Comic View Mode</th>
                <th>Image</th>
                <th class="text-end">
                  Actions
                </th>
              </tr>
            </thead>

            <tbody id="sortableList">
              <% pages.forEach((page, index) => { %>
                <tr
                  class="page-sort-row"
                  draggable="true"
                  data-page-id="<%= page.id %>"
                >
                  <td>
                    <span
                      class="drag-handle"
                      title="Drag to reorder"
                    >
                      <i class="bi bi-grip-vertical"></i>
                      Drag
                    </span>
                  </td>

                  <td>
                    <span
                      class="badge bg-primary-lt page-number-badge"
                    >
                      Page <%= page.page_number || index + 1 %>
                    </span>
                  </td>

                  <td>
                    <% if (page.image_url) { %>
                      <img
                        src="<%= page.image_url %>"
                        class="rounded"
                        alt="Page <%= page.page_number || index + 1 %>"
                        loading="lazy"
                        style="
                          width: 80px;
                          height: 120px;
                          object-fit: cover;
                        "
                      >
                    <% } else { %>
                      <div
                        class="border rounded d-flex align-items-center justify-content-center"
                        style="
                          width: 80px;
                          height: 120px;
                        "
                      >
                        <i class="bi bi-image"></i>
                      </div>
                    <% } %>
                  </td>

                  <td>
                    <span class="badge bg-azure-lt">
                      <%= comic?.view_mode || "vertical" %>
                    </span>
                  </td>

                  <td class="small text-muted text-break">
                    <%= page.image_url || "No image" %>
                  </td>

                  <td class="text-end">
                    <div class="btn-list justify-content-end">
                      <a
                        href="/admin/pages/edit/<%= page.id %>"
                        class="btn btn-outline-warning btn-sm"
                      >
                        <i class="bi bi-pencil-square me-1"></i>
                        Edit
                      </a>

                      <a
                        href="/admin/pages/delete/<%= page.id %>"
                        class="btn btn-outline-danger btn-sm js-delete-page"
                      >
                        <i class="bi bi-trash me-1"></i>
                        Delete
                      </a>
                    </div>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    </div>
  </div>
</div>

<script
  src="/js/page-sort.js"
  defer
></script>